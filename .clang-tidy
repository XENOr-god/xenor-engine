Checks: >
  bugprone-*,
  clang-analyzer-*,
  modernize-*,
  performance-*,
  readability-*,
  -modernize-use-trailing-return-type,
  -readability-magic-numbers,
  -readability-identifier-length,
  -readability-function-cognitive-complexity
WarningsAsErrors: ''
HeaderFilterRegex: '^(include|src|tests|examples|benchmarks)/'
FormatStyle: file
